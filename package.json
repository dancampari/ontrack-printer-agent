{
  "name": "ontrack-printer-agent",
  "productName": "OnTrack Agent",
  "version": "3.9.5",
  "author": "OnTrack",
  "description": "Agente de impressão térmica para o sistema OnTrack",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "release": "electron-builder --publish always",
    "test": "node --test test/regression.test.js test/printer-validator.test.js test/pshost.test.js test/printer-usb.test.js test/monitor-queries.test.js test/ws-broadcast.test.js",
    "predist": "npm test",
    "prerelease": "npm test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "body-parser": "^1.20.3",
    "cors": "^2.8.6",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "iconv-lite": "^0.6.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "pkg": "^5.8.1"
  },
  "build": {
    "appId": "com.ontrack.printer-agent",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!*.ts",
      "!test/**",
      "!.github/**"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "OnTrack-Agent-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dancampari",
        "repo": "ontrack-printer-agent",
        "releaseType": "release"
      }
    ]
  }
}
